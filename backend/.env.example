# Copy this file to .env and fill in the values.
# The application reads these via pydantic-settings (python-dotenv).

# ── General ──────────────────────────────────────────────────────────────────
APP_NAME="Real-Time Sign Language Translator"

# Set to true only during local development. Never true in production —
# it causes FastAPI to return full Python tracebacks in HTTP 500 responses.
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated JSON list of allowed frontend origins.
# In production replace localhost entries with your real domain(s).
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true
MONGO_URI=mongodb://localhost:27017
MONGO_DB=sign_language_translator

# ── ML model ─────────────────────────────────────────────────────────────────
# Path to the trained classifier bundle produced by ml/train.py.
# Run:  cd backend && python -m ml.train
MODEL_PATH=ml/classifier.pkl

# ── Text-to-speech ────────────────────────────────────────────────────────────
# Words per minute (pyttsx3 default is ~175).
SPEECH_RATE=175
# 0.0 (silent) – 1.0 (full volume).
SPEECH_VOLUME=1.0
