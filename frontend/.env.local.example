# Copy this file to .env.local for local development.
# Next.js automatically loads .env.local and makes NEXT_PUBLIC_* variables
# available in the browser bundle.

# ── Backend URL ───────────────────────────────────────────────────────────────
# Development: point directly at the FastAPI server.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (same-domain proxy via Next.js rewrites):
#   Set this to an empty string so axios uses a relative base URL and all
#   /api/* and /health requests are forwarded by the rewrites in next.config.js.
#   This eliminates cross-origin requests entirely — no CORS required.
# NEXT_PUBLIC_API_URL=
